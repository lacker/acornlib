theorem relation_pullback_eq_relation_respects_unary_op[A, B](f: A -> B, op_a: A -> A, op_b: B -> B) {
    preserves_unary_op(f, op_a, op_b) implies respects_unary_op(relation_pullback(f, eq_relation[B]), op_a)
