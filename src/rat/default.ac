theorem rat_total(a: Rat, b: Rat) { a <= b or b <= a } by {
    if a < b {
        a <= b
    } else {
        if a = b {
            a <= b
        } else {
            a > b
            a > b = b < a
            b <= a
        }
    }
}

theorem lte_add_right(a: Rat, b: Rat, c: Rat) {
    a <= b implies a + c <= b + c
} by {
    if a = b {
        a + c = b + c
    } else {
        a < b
        a + c <= b + c
    }
}

theorem lte_add_left(a: Rat, b: Rat, c: Rat) {
    b <= c implies a + b <= a + c
} by {
    a + b = b + a
    a + c = c + a
    b + a <= c + a
}

