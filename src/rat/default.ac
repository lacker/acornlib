theorem times_three(x: Rat) {
    Rat.3 * x = x + x + x
} by {
    Int.3 = Int.2 + Int.1
    Rat.2 * x + Rat.1 * x = (Rat.2 + Rat.1) * x
    Rat.from_int(Int.2) + Rat.from_int(Int.1) = Rat.from_int(Int.2 + Int.1)
    Rat.2 * x = x + x
    Rat.1 * x = x
}

theorem three_thirds(x: Rat) {
