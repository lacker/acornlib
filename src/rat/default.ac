}

theorem rat_lte_meet_of_bounds(c: Rat, a: Rat, b: Rat) {
    c <= a and c <= b implies c <= a.meet(b)
} by {
    if c <= a and c <= b {
        lte_min_of_bounds(c, a, b)
        c <= a.meet(b)
    }
}

