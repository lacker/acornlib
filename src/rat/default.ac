theorem div_zero(a: Rat) {
    a / Rat.0 = Rat.0
} by {
    Rat.0.num = Int.0
    reduce(Rat.0.denom, Int.0) = Rat.0
    reduce(Rat.0.denom, Rat.0.num) = Rat.0.inverse
    Rat.0.inverse = Rat.0
    a * Rat.0.inverse = a / Rat.0
}

