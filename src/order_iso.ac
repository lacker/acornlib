) {
    function_order_iso_unmap(inverse_order_iso(e), f) = function_order_iso_map(e, f)
} by {
    forall(x: X) {
        inverse_order_iso_inv(e)
        inverse_order_iso(e).inv = e.map
        function_order_iso_unmap(inverse_order_iso(e), f, x) =
