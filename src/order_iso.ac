        is_upper_bound(order_dual_iso_preimage_predicate(e, q), e.inv(a))
        upper_bound_imp_bounded_above(order_dual_iso_preimage_predicate(e, q), e.inv(a))
        is_bounded_above(order_dual_iso_preimage_predicate(e, q))
