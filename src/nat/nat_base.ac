theorem mul_suc_left(a: Nat, b: Nat) { a.suc * b = b + a * b } by {
    define f(x: Nat) -> Bool { a.suc * x = x + a * x }
    a.suc * 0 = 0 + a * 0
    forall(x: Nat) {
        if f(x) {
            x + a * x = a.suc * x
            a + a * x = a * x + a
            x.suc + (a + a * x) = (x + (a + a * x)).suc
            a.suc + a.suc * x = (a + a.suc * x).suc
            a + a.suc * x = a.suc * x + a
            a.suc * x.suc = x.suc + (a + a * x)
            f(x.suc)
        }
    }
    f(b)
}

