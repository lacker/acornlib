theorem divides_suc(a: Nat, b: Nat) { a.divides(b) and a.divides(b.suc) implies a = 1 } by {
    let (c: Nat) satisfy { a * c = b }
    let (d: Nat) satisfy { a * d = b.suc }
    if a = 0 {
        0 * d = 0
        b.suc = 0
        false
    }
    a * c < a * d
    c < d
    let (e: Nat) satisfy { c + e = d and e != 0 }
    a * (c + e) = a * d
    a * (c + e) = a * c + a * e
    a * c + a * e = b.suc
    b + a * e = b + 1
    a * e = 1
    a = 1
}

theorem exists_infinite_primes(n: Nat) {
    exists(p: Nat) {
