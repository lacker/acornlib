/// Multiplication is defined recursively.
instance Nat: Mul {
    define mul(self, b: Nat) -> Nat {
        match b {
            Nat.zero {
                0
            }
            Nat.suc(pred) {
                Mul.mul[Nat](self, pred) + self
            }
        }
    }
}

