}

theorem add_assoc(a: Nat, b: Nat, c: Nat) { a + b + c = a + (b + c) } by {
    define f(x: Nat) -> Bool { x + b + c = x + (b + c) }
    forall(x: Nat) {
        if f(x) {
            (x + b + c).suc = (x + b).suc + c
            (x + (b + c)).suc = x.suc + (b + c)
            (x + b).suc = x.suc + b
            x + (b + c) = x + b + c implies f(x.suc)
            f(x.suc)
        }
    }
