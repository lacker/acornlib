theorem add_comm(a: Nat, b: Nat) { a + b = b + a } by {
    define f(x: Nat) -> Bool { x + b = b + x }
    f(0)
    forall(x: Nat) {
        if f(x) {
            x.suc + b = (x + b).suc
            b + x.suc = (b + x).suc
