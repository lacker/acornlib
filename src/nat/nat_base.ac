theorem lte_mul_both(a: Nat, b: Nat, c: Nat) { b <= c implies a * b <= a * c } by {
    if b <= c {
        let d: Nat satisfy { b + d = c }
        a * b + a * d = a * (b + d)
        a * b + a * d = a * c
        a * b <= a * c
    }
}

theorem lt_mul_both(a: Nat, b: Nat, c: Nat) { a != 0 and b < c implies a * b < a * c } by {
