}

/// Addition is defined recursively.
instance Nat: Add {
    define add(self, other: Nat) -> Nat {
        match other {
            Nat.zero {
                self
            }
            Nat.suc(pred) {
                Add.add[Nat](self, pred).suc
            }
        }
    }
}

