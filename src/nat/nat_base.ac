        let c: Nat satisfy { a + c = b }
        if c = 0 {
            a + 0 = a
            a + 0 = b
            a + 0 < b
            not a + 0 < b or a + 0 != b
            false
        }
        c != 0
        a + c = b and c != 0
        exists(d: Nat) { a + d = b and d != 0 }
    }
}

