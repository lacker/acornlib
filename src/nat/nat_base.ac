/// `a <= b` if there's a natural number that can be added to `a` to get `b`.
instance Nat: LTE {
    define lte(self, b: Nat) -> Bool {
        exists(c: Nat) {
            self + c = b
        }
    }
}

theorem lte_ref(a: Nat) {
    a <= a
}

