theorem lt_suc_left(a: Nat, b: Nat) { a < b implies a.suc = b or a.suc < b } by {
    let (c: Nat) satisfy { a + c = b and c != 0 }
    let (d: Nat) satisfy { d.suc = c }
    if d = 0 {
        c = 1
        a + 1 = b
        a + 1 = (a + 0).suc
        a + 0 = a
        a.suc = b
    } else {
        let (e: Nat) satisfy { e.suc = d }
        a + d.suc = b
        a + d.suc = (a + d).suc
        a.suc + d = (a + d).suc
        a.suc + d = b
        a.suc + e.suc = b
        a.suc < a.suc + e.suc
        a.suc < b
    }
}

