numerals Nat

/// Small addition facts used by the one-digit multiplication table.
theorem nat_add_0_1 {
    0 + 1 = 1
} by {
    1 = 0.suc
    0 + 1 = (0 + 0).suc
    0 + 0 = 0
    1 = 0.suc
}

theorem nat_add_0_2 {
    0 + 2 = 2
} by {
    2 = 1.suc
    0 + 2 = (0 + 1).suc
    nat_add_0_1
