    a.max(b) <= a.max(b.max(c))
    lte_max_right(a.max(b), c)
    c <= a.max(b.max(c))
    a.max(b).max(c) <= a.max(b.max(c))
    max_lte_iff(a, b.max(c), a.max(b).max(c))
    lte_max_iff(a, b, a.max(b).max(c))
    lte_max_left(a.max(b), c)
    a.max(b) <= a.max(b).max(c)
    lte_max_iff(a, b, a.max(b).max(c))
    lte_max_left(a.max(b), c)
    max_imp_gte(a, b)
    a.max(b) >= b
    b <= a.max(b)
    lte_trans(b, a.max(b), a.max(b).max(c))
    b <= a.max(b).max(c)
    b.max(c) <= a.max(b).max(c)
    a <= a.max(b).max(c)
    b.max(c) <= a.max(b).max(c)
    a.max(b.max(c)) <= a.max(b).max(c)
}

