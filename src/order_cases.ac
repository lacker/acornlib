theorem min_assoc[L: LinearOrder](a: L, b: L, c: L) {
    a.min(b).min(c) = a.min(b.min(c))
} by {
    lte_antisymm(a.min(b).min(c), a.min(b.min(c)))
    lte_min_iff(a.min(b).min(c), a, b.min(c))
    min_lte_left(a.min(b), c)
    min_lte_left(a, b)
    lte_trans(a.min(b).min(c), a.min(b), a)
    a.min(b).min(c) <= a
    lte_min_iff(a.min(b).min(c), b, c)
    min_lte_left(a.min(b), c)
    min_lte_right(a, b)
    lte_trans(a.min(b).min(c), a.min(b), b)
    min_lte_right(a.min(b), c)
    a.min(b).min(c) <= c
    a.min(b).min(c) <= b.min(c)
    a.min(b).min(c) <= a.min(b.min(c))
    lte_min_iff(a.min(b.min(c)), a.min(b), c)
    lte_min_iff(a.min(b.min(c)), a, b)
    min_lte_left(a, b.min(c))
    min_lte_left(a, b.min(c))
    a.min(b.min(c)) <= a
    min_lte_right(a, b.min(c))
    min_lte_left(b, c)
    lte_trans(a.min(b.min(c)), b.min(c), b)
    a.min(b.min(c)) <= b
    a.min(b.min(c)) <= a.min(b)
    min_lte_right(a, b.min(c))
    min_lte_right(b, c)
    lte_trans(a.min(b.min(c)), b.min(c), c)
    a.min(b.min(c)) <= c
    a.min(b.min(c)) <= a.min(b).min(c)
}

theorem max_assoc[L: LinearOrder](a: L, b: L, c: L) {
    a.max(b).max(c) = a.max(b.max(c))
} by {
    lte_antisymm(a.max(b).max(c), a.max(b.max(c)))
    max_lte_iff(a.max(b), c, a.max(b.max(c)))
    lte_max_iff(a, b, a.max(b.max(c)))
    lte_max_left(a, b.max(c))
    a <= a.max(b.max(c))
    lte_max_iff(a, b, a.max(b.max(c)))
    lte_max_left(a, b.max(c))
    lte_max_right(b, c)
