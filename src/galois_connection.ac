        lte_refl(x)
        lte_galois_coinsertion_meet_of_bounds(lower, upper, x, x, x)
        x <= galois_coinsertion_meet(lower, upper, x, x)
        lte_antisymm(galois_coinsertion_meet(lower, upper, x, x), x)
        galois_coinsertion_meet(lower, upper, x, x) = x
    }
}

