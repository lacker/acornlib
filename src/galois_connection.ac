        xy <= lhs
        galois_insertion_lte_join_left(lower, upper, x, y)
        x <= xy
        lte_trans(x, xy, lhs)
        x <= lhs
        galois_insertion_lte_join_right(lower, upper, xy, z)
        z <= lhs
        galois_insertion_lte_join_left(lower, upper, xy, z)
        xy <= lhs
