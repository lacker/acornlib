/// Preimage commutes with flattened binary-family set suprema.
theorem set_preimage_sSup_pair_family[T, U, I, J](f: T -> U, family: (I, J) -> Set[U]) {
    set_preimage(f, set_sSup(set_pair_family(family))) =
