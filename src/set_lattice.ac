}

/// Families with the same occurring lower-bound members have the same infimum.
theorem set_sInf_eq_of_family_occurs[K, I, J](a: I -> Set[K], b: J -> Set[K]) {
    (forall(j: J) { exists(i: I) { a(i) = b(j) } }) and
    (forall(i: I) { exists(j: J) { b(j) = a(i) } })
