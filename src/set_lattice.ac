/// Pointwise inclusion of binary families preserves flattened suprema.
theorem set_sSup_pair_family_monotone[K, I, J](a: (I, J) -> Set[K],
    b: (I, J) -> Set[K]) {
    (forall(i: I) { forall(j: J) { a(i, j).subset(b(i, j)) } }) implies
