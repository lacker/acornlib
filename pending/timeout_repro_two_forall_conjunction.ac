/// Reproducer: packaging two universal facts into a conjunction hits the
/// activation cap in Acorn 0.1.72.
///
/// See https://github.com/acornprover/acorn/issues/48.
theorem timeout_repro_two_forall_conjunction[T](p: T -> Bool, q: T -> Bool) {
    (forall(x: T) { p(x) }) implies
    (forall(x: T) { q(x) }) implies
    (forall(x: T) { p(x) }) and (forall(x: T) { q(x) })
} by {
    (forall(x: T) { p(x) }) and (forall(x: T) { q(x) })
}
